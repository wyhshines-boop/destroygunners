---
import { ClientRouter } from "astro:transitions";
import bg1 from "../img/bg1.jpg";
import bg2 from "../img/bg2.webp";
import bg3 from "../img/bg3.webp";
import bg4 from "../img/bg4.webp";
import bg5 from "../img/bg5.webp";
import Header from "../components/Header.astro";
import { getLangFromUrl } from "../i18n/translations";

const lang = getLangFromUrl(Astro.url);
const bgSrcs = [bg1, bg2, bg3, bg4, bg5].map(b => b.src);
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="A fan-built hub for the Destroy Gunners mecha series by SHADE Inc. Offline patches, game archives, and a growing community." />
		<title>Destroy Gunners — Offline Patch Download & Community</title>
		<ClientRouter />
		<!-- Google tag (gtag.js) -->
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-QXY8D8TC12"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-QXY8D8TC12');
		</script>
	</head>
	<body>
		<script is:inline>
			(function() {
				if (sessionStorage.getItem('lang-redirected')) return;
				sessionStorage.setItem('lang-redirected', '1');
				var isZh = navigator.language && navigator.language.startsWith('zh');
				var onZh = location.pathname.startsWith('/zh');
				if (isZh && !onZh) {
					location.replace('/zh' + location.pathname);
				}
			})();
		</script>
		<Header />
		<slot />
		<script is:inline define:vars={{ bgSrcs }}>
			window.__bgSrcs = bgSrcs;
			window.__bgChosen = window.__bgChosen || bgSrcs[Math.floor(Math.random() * bgSrcs.length)];
		</script>
		<script>
			function applyBg() {
				if (window.__bgChosen) {
					document.body.style.backgroundImage = `linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.65)), url('${window.__bgChosen}')`;
				}
			}
			document.addEventListener('astro:page-load', applyBg);
		</script>
	</body>
</html>

<style is:global>
	@font-face {
		font-family: "RetroTerminal";
		src: local("Courier New"), local("Courier"), monospace;
	}

	html {
		height: 100%;
	}

	body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100vh;
		background-color: #000;
		background-size: cover;
		background-position: center center;
		background-attachment: fixed;
		background-repeat: no-repeat;
		color: #e0ffff;
		font-family: "Noto Sans", sans-serif;
		font-weight: 300;
		line-height: 1.5;
	}

	a {
		color: #00f0ff;
		text-decoration: none;
	}

	a:hover {
		color: #fff;
		text-shadow: 0 0 5px #00f0ff;
	}

	* {
		box-sizing: border-box;
	}
</style>
