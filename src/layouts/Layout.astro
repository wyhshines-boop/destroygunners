---
import { ClientRouter } from "astro:transitions";
import bg1 from "../img/bg1.jpg";
import bg2 from "../img/bg2.webp";
import bg3 from "../img/bg3.webp";
import bg4 from "../img/bg4.webp";
import bg5 from "../img/bg5.webp";
import Header from "../components/Header.astro";
import { getLangFromUrl } from "../i18n/translations";

const lang = getLangFromUrl(Astro.url);
const bgSrcs = [bg1, bg2, bg3, bg4, bg5].map(b => b.src);
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : lang === 'ja' ? 'ja-JP' : 'en'}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@300;400;500;700&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="A fan-built hub for the Destroy Gunners mecha series by SHADE Inc. Offline patches, game archives, and a growing community." />
		<title>Destroy Gunners — Offline Patch Download & Community</title>
		<ClientRouter />
		<!-- Google tag (gtag.js) -->
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-QXY8D8TC12"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-QXY8D8TC12');
		</script>
	</head>
	<body>
		<script is:inline>
			(function() {
				if (sessionStorage.getItem('lang-redirected')) return;
				sessionStorage.setItem('lang-redirected', '1');
				var browserLang = navigator.language || '';
				var path = location.pathname;
				var isZh = browserLang.startsWith('zh');
				var isJa = browserLang.startsWith('ja');
				var onZh = path.startsWith('/zh');
				var onJa = path.startsWith('/ja');
				
				if (isZh && !onZh && !onJa) location.replace('/zh' + path);
				else if (isJa && !onJa && !onZh) location.replace('/ja' + path);
			})();
		</script>
		<Header />
		<slot />
		<script is:inline define:vars={{ bgSrcs }}>
			window.__bgSrcs = bgSrcs;
			window.__bgChosen = window.__bgChosen || bgSrcs[Math.floor(Math.random() * bgSrcs.length)];
		</script>
		<script>
			document.addEventListener('astro:page-load', () => {
				if (window.__bgChosen) {
					document.documentElement.style.setProperty('--bg-image', `url('${window.__bgChosen}')`);
				}
			});
		</script>
	</body>
</html>

<style is:global>
	@font-face {
		font-family: "RetroTerminal";
		src: local("Courier New"), local("Courier"), monospace;
	}

	html {
		height: 100%;
	}

	body {
		margin: 0;
		padding: 0;
		width: 100%;
		min-height: 100vh;
		background-color: #000;
		color: #e0ffff;
		font-family: "Roboto Mono", monospace;
		font-weight: 300;
		line-height: 1.5;
	}

	/* Fixed Background layered to fix mobile scrolling jitter */
	body::before {
		content: "";
		position: fixed;
		top: 0;
		left: 0;
		width: 100vw;
		height: 100vh;
		height: 100lvh;
		z-index: -1;
		background-color: #000;
		background-image: 
			linear-gradient(rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.25)),
			var(--bg-image);
		background-size: cover;
		background-position: center center;
		background-repeat: no-repeat;
		/* Using pointer-events none to ensure it doesn't block clicks */
		pointer-events: none;
	}

	a {
		color: #00f0ff;
		text-decoration: none;
	}

	a:hover {
		color: #fff;
		text-shadow: 0 0 5px #00f0ff;
	}

	* {
		box-sizing: border-box;
	}
</style>
