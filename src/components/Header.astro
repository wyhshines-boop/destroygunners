---
import logoImg from '../img/logo.webp';
import { getLangFromUrl, t, getLocalizedPath } from '../i18n/translations';

const lang = getLangFromUrl(Astro.url);
const tr = t(lang);
const switchLang = lang === 'en' ? 'zh' : (lang === 'zh' ? 'ja' : 'en');
const switchLabel = lang === 'en' ? '中文' : (lang === 'zh' ? '日本語' : 'EN');

const currentPath = Astro.url.pathname;
const basePath = lang === 'zh' ? currentPath.replace(/^\/zh/, '') || '/' : currentPath;
const switchHref = getLocalizedPath(basePath, switchLang);
---
<header class="global-navbar">
	<div class="nav-container">
		<div class="logo">
			<a href={getLocalizedPath('/', lang)}><img src={logoImg.src} alt="Destroy Gunners" class="logo-img" /></a>
		</div>
		<div class="nav-right">
			<nav class="nav-links" id="nav-links">
				<a href={getLocalizedPath('/', lang)} class={basePath === '/' ? 'active' : ''}>{tr.nav.home}</a>
				<a href={getLocalizedPath('/games', lang)} class={basePath.startsWith('/games') ? 'active' : ''}>{tr.nav.games}</a>
				<a href={getLocalizedPath('/story', lang)} class={basePath.startsWith('/story') ? 'active' : ''}>{tr.nav.story}</a>
				<a href={getLocalizedPath('/mechas', lang)} class={basePath.startsWith('/mechas') ? 'active' : ''}>{tr.nav.mecha}</a>
				<div class="mobile-break"></div>
				<a href={getLocalizedPath('/enemies', lang)} class={basePath.startsWith('/enemies') ? 'active' : ''}>{tr.nav.enemy}</a>
				<a href={getLocalizedPath('/assets', lang)} class={basePath.startsWith('/assets') ? 'active' : ''}>{tr.nav.assets}</a>
			</nav>
			<div class="nav-actions">
				<a href={switchHref} class="lang-switch" aria-label={switchLabel} title={switchLabel}>
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="10"></circle>
						<line x1="2" y1="12" x2="22" y2="12"></line>
						<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
					</svg>
				</a>
				<button class="bgm-toggle" id="bgm-toggle" aria-label="Toggle BGM">
					<svg class="icon-muted" id="icon-muted" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
						<line x1="23" y1="9" x2="17" y2="15"></line>
						<line x1="17" y1="9" x2="23" y2="15"></line>
					</svg>
					<svg class="icon-playing" id="icon-playing" style="display:none;" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
						<path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
						<path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
					</svg>
				</button>
			</div>
		</div>
	</div>
</header>

<script>
	// BGM setup - runs once, persists across page navigations
	(function initBgm() {
		if (window.__bgmInitDone) return;
		window.__bgmInitDone = true;

		const bgms = [0, 1, 2, 4, 5, 10].map(i => `/audio/bgm_${i}.ogg`);
		const chosen = bgms[Math.floor(Math.random() * bgms.length)];
		const audio = new Audio(chosen);
		audio.loop = true;
		audio.volume = 0.5;
		window.__bgmAudio = audio;
		window.__bgmPlaying = false;
	})();

	document.addEventListener('astro:page-load', () => {


		// BGM toggle
		const toggleBtn = document.getElementById('bgm-toggle');
		const iconMuted = document.getElementById('icon-muted');
		const iconPlaying = document.getElementById('icon-playing');

		if (toggleBtn && iconMuted && iconPlaying) {
			// Sync icon with current state
			if (window.__bgmPlaying) {
				iconMuted.style.display = 'none';
				iconPlaying.style.display = 'block';
			} else {
				iconMuted.style.display = 'block';
				iconPlaying.style.display = 'none';
			}

			if (!toggleBtn.dataset.init) {
				toggleBtn.dataset.init = 'true';
				toggleBtn.addEventListener('click', () => {
					const audio = window.__bgmAudio;
					if (!audio) return;

					const mIcon = document.getElementById('icon-muted');
					const pIcon = document.getElementById('icon-playing');

					if (window.__bgmPlaying) {
						audio.pause();
						window.__bgmPlaying = false;
						if (mIcon) mIcon.style.display = 'block';
						if (pIcon) pIcon.style.display = 'none';
					} else {
						audio.play().catch(() => {});
						window.__bgmPlaying = true;
						if (mIcon) mIcon.style.display = 'none';
						if (pIcon) pIcon.style.display = 'block';
					}
				});
			}
		}
	});

	// Type declarations
	declare global {
		interface Window {
			__bgmInitDone?: boolean;
			__bgmAudio?: HTMLAudioElement;
			__bgmPlaying?: boolean;
		}
	}
</script>

<style>
	.global-navbar {
		background: rgba(0, 15, 20, 0.9);
		border-bottom: 2px solid #00f0ff;
		box-shadow: 0 0 15px rgba(0, 240, 255, 0.4);
		position: sticky;
		top: 0;
		z-index: 1000;
		padding: 0 20px;
	}

	.nav-container {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 30px;
		height: 60px;
	}

	.nav-right {
		display: contents;
	}

	.logo-img {
		height: 40px;
		width: auto;
		display: block;
	}

	.logo a:hover .logo-img {
		filter: drop-shadow(0 0 5px #00f0ff);
	}

	.bgm-toggle {
		background: none;
		border: none;
		color: #e0ffff;
		cursor: pointer;
		padding: 5px;
		display: flex;
		align-items: center;
		transition: color 0.2s;
	}

	.bgm-toggle:hover {
		color: #00f0ff;
	}



	.nav-links {
		display: flex;
		gap: 20px;
	}

	.nav-links a {
		position: relative;
		font-size: 1rem;
		padding: 4px 8px;
		transition: all 0.2s;
	}

	.nav-links a:hover,
	.nav-links a.active {
		background: rgba(0, 240, 255, 0.25);
		text-shadow: 0 0 5px rgba(0, 240, 255, 0.5);
	}

	.mobile-break {
		display: none;
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 15px;
	}

	.lang-switch {
		color: #e0ffff;
		text-decoration: none;
		display: flex;
		align-items: center;
		padding: 5px;
		transition: color 0.2s;
	}

	.lang-switch:hover {
		color: #00f0ff;
	}

	@media (max-width: 800px) {
		.nav-container {
			flex-wrap: nowrap;
			height: auto;
			padding: 10px 0;
			justify-content: space-between;
			align-items: center;
			gap: 10px;
		}

		.nav-right {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			justify-content: center;
			gap: 0 12px;
			flex: 1;
		}

		.nav-links, .nav-actions {
			display: contents;
		}

		.nav-links a {
			padding: 2px 4px;
			width: auto;
			text-align: left;
			white-space: nowrap;
			font-size: 0.85rem;
			line-height: 1.2;
		}

		.mobile-break {
			display: block;
			flex-basis: 100%;
			height: 0;
		}

		.logo-img {
			height: 44px;
		}

		.bgm-toggle, .lang-switch {
			margin-left: 5px;
		}
	}

</style>
