---
import ContentBox from './ContentBox.astro';
import borderImg from '../img/border.webp';
import buttonImg from '../img/button.webp';
import { type Lang, t } from '../i18n/translations';
import Giscus from './Giscus.astro';

import ScreenshotGallery from './ScreenshotGallery.astro';

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
---

<div class="container">
	<main>
		<ContentBox title={tr.notifications.title}>
			<div class="version-tabs">
				{tr.notifications.versions.map((v, i) => (
					<button 
						class={`version-tab ${i === 0 ? 'active' : ''}`} 
						data-version-id={v.id}
						data-apk={v.apk}
						data-has-mirror={String(v.hasMirror)}
						data-google-drive={v.mirrors?.googleDrive}
						data-lanzou={v.mirrors?.lanzou}
						data-lanzou-pw={v.mirrors?.lanzouPw}
					>
						{v.name}
					</button>
				))}
			</div>

			<div id="notifications-container">
				{tr.notifications.versions.map((v, i) => (
					<div class={`version-content ${i === 0 ? 'active' : ''}`} id={`version-content-${v.id}`}>
						{v.sections.map(section => (
							<div class="notification-item">
								<h3 class="cyan-text">{section.title}</h3>
								<ul>
									{section.items.map(item => <li>{item}</li>)}
								</ul>
							</div>
						))}
					</div>
				))}
			</div>

			<div class="download-btn-wrap">
				<button
					id="open-download"
					class="retro-btn"
					data-apk={tr.notifications.versions[0].apk}
					data-has-mirror={String(tr.notifications.versions[0].hasMirror)}
					data-google-drive={tr.notifications.versions[0].mirrors?.googleDrive}
					data-lanzou={tr.notifications.versions[0].mirrors?.lanzou}
					data-lanzou-pw={tr.notifications.versions[0].mirrors?.lanzouPw}
					style={`background-image: url('${buttonImg.src}');`}
				>
					<span class="btn-inner">{tr.download.button}</span>
				</button>
			</div>

			<ScreenshotGallery />
		</ContentBox>

		<ContentBox title={tr.about.title}>
			<p>{tr.about.description}</p>
			<p>{tr.about.contact} <a href="mailto:wyhshines@gmail.com">wyhshines@gmail.com</a></p>
		</ContentBox>
	</main>

	<Giscus lang={lang} />

	<footer class="site-footer">
		<p>{tr.footer}</p>
	</footer>
</div>

<!-- Download Modal -->
<div id="download-modal" class="modal-overlay">
	<div class="modal-box" style={`--border-img: url('${borderImg.src}');`}>
		<h2 class="modal-title">{tr.download.title}</h2>
		<div class="modal-content">
			<a
				id="modal-download-direct"
				href="/downloads/DGunsZZ_3.0.0a.apk"
				download
				class="retro-btn download-track"
				data-method="direct"
				style={`background-image: url('${buttonImg.src}');`}
			>
				<span class="btn-inner">{tr.download.direct}</span>
			</a>
			<div id="mirror-links" class="mirror-links">
				<a
					id="modal-download-google"
					href="#"
					target="_blank"
					rel="noopener"
					class="retro-btn download-track"
					data-method="google_drive"
					style={`background-image: url('${buttonImg.src}');`}
				>
					<span class="btn-inner">{tr.download.googleDrive}</span>
				</a>
				<a
					id="modal-download-lanzou"
					href="#"
					target="_blank"
					rel="noopener"
					class="retro-btn download-track"
					data-method="lanzou_cloud"
					style={`background-image: url('${buttonImg.src}');`}
				>
					<span class="btn-inner" id="lanzou-btn-text">
						{tr.download.lanzou}
					</span>
				</a>
			</div>
		</div>
		<button id="close-download" class="close-btn">&times;</button>
	</div>
</div>

<script>
	const sfxOpen = new Audio('/audio/button1.ogg');
	const sfxClose = new Audio('/audio/button2.ogg');

	function playSound(audio: HTMLAudioElement) {
		audio.currentTime = 0;
		audio.play().catch(() => {});
	}

	function initVersionSwitcher() {
		const tabs = document.querySelectorAll('.version-tab');
		const contents = document.querySelectorAll('.version-content');
		const mainDownloadBtn = document.getElementById('open-download');

		tabs.forEach(tab => {
			tab.addEventListener('click', () => {
				playSound(sfxOpen);
				const versionId = (tab as HTMLElement).dataset.versionId;
				const apk = (tab as HTMLElement).dataset.apk;
				const hasMirror = (tab as HTMLElement).dataset.hasMirror;

				// Update tabs
				tabs.forEach(t => t.classList.remove('active'));
				tab.classList.add('active');

				// Update content
				contents.forEach(c => {
					if (c.id === `version-content-${versionId}`) {
						c.classList.add('active');
					} else {
						c.classList.remove('active');
					}
				});

				// Update main download button data
				if (mainDownloadBtn) {
					mainDownloadBtn.dataset.apk = (tab as HTMLElement).dataset.apk;
					mainDownloadBtn.dataset.hasMirror = (tab as HTMLElement).dataset.hasMirror;
					mainDownloadBtn.dataset.googleDrive = (tab as HTMLElement).dataset.googleDrive;
					mainDownloadBtn.dataset.lanzou = (tab as HTMLElement).dataset.lanzou;
					mainDownloadBtn.dataset.lanzouPw = (tab as HTMLElement).dataset.lanzouPw;
				}
			});
		});
	}

	function initModal() {
		const openBtn = document.getElementById("open-download");
		const modal = document.getElementById("download-modal");
		const closeBtn = document.getElementById("close-download");
		const modalBox = modal?.querySelector(".modal-box");
		
		const modalDirectLink = document.getElementById('modal-download-direct') as HTMLAnchorElement;
		const mirrorLinks = document.getElementById('mirror-links');

		if (!openBtn || !modal) return;

		function closeModal() {
			playSound(sfxClose);
			modal!.classList.add("closing");
			modal!.classList.remove("active");
			modalBox?.addEventListener(
				"transitionend",
				() => {
					modal!.classList.remove("closing");
				},
				{ once: true },
			);
		}

		openBtn.addEventListener("click", () => {
			playSound(sfxOpen);
			
			const { apk, hasMirror, googleDrive, lanzou, lanzouPw } = openBtn.dataset;

			// Update modal content based on current version data from button
			if (modalDirectLink) {
				modalDirectLink.href = apk || '';
			}
			
			if (mirrorLinks) {
				mirrorLinks.style.display = hasMirror === 'true' ? 'block' : 'none';
				
				const googleLink = document.getElementById('modal-download-google') as HTMLAnchorElement;
				const lanzouLink = document.getElementById('modal-download-lanzou') as HTMLAnchorElement;
				const lanzouText = document.getElementById('lanzou-btn-text');

				if (googleLink) googleLink.href = googleDrive || '#';
				if (lanzouLink) lanzouLink.href = lanzou || '#';
				if (lanzouText) {
					const lang = document.documentElement.lang || 'en';
					// Simple hack to get labels without full i18n object in client script
					const pwLabel = lang === 'zh' ? '密码' : (lang === 'ja' ? 'パスワード' : 'Password');
					const lanzouLabel = lang === 'zh' ? '蓝奏云' : (lang === 'ja' ? 'Lanzou Cloud' : 'Lanzou Cloud');
					lanzouText.textContent = `${lanzouLabel} (${pwLabel}: ${lanzouPw})`;
				}
			}

			modal.classList.remove("closing");
			modal.classList.add("active");
		});

		closeBtn?.addEventListener("click", closeModal);

		modal.addEventListener("click", (e) => {
			if (e.target === modal) closeModal();
		});
	}

	function initDownloadTracking() {
		document.querySelectorAll('.download-track').forEach(btn => {
			if ((btn as HTMLElement).dataset.tracked) return;
			(btn as HTMLElement).dataset.tracked = 'true';
			btn.addEventListener('click', () => {
				playSound(sfxOpen);
				const method = (btn as HTMLElement).dataset.method;
				// @ts-ignore
				if (typeof gtag === 'function') {
					// @ts-ignore
					gtag('event', 'download', {
						event_category: 'apk',
						event_label: method,
					});
				}
			});
		});
	}

	initVersionSwitcher();
	initModal();
	initDownloadTracking();
	document.addEventListener("astro:page-load", () => {
		initVersionSwitcher();
		initModal();
		initDownloadTracking();
	});
</script>

<style>
	.container {
		max-width: 1100px;
		margin: 0 auto;
		padding: 40px 20px;
	}

	.version-tabs {
		display: flex;
		gap: 15px;
		margin-bottom: 30px;
		border-bottom: 1px solid rgba(0, 240, 255, 0.1);
		padding-bottom: 15px;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
		scrollbar-width: thin;
		scrollbar-color: #00f0ff rgba(0, 240, 255, 0.1);
	}

	.version-tabs::-webkit-scrollbar {
		height: 3px;
	}

	.version-tabs::-webkit-scrollbar-track {
		background: rgba(0, 240, 255, 0.1);
	}

	.version-tabs::-webkit-scrollbar-thumb {
		background: #00f0ff;
		box-shadow: 0 0 4px rgba(0, 240, 255, 0.6);
	}

	.version-tab {
		background: rgba(0, 240, 255, 0.05);
		border: 1px solid rgba(0, 240, 255, 0.25);
		color: rgba(224, 255, 255, 0.6);
		padding: 8px 20px;
		white-space: nowrap;
		flex-shrink: 0;
		cursor: pointer;
		font-family: inherit;
		font-size: 0.85rem;
		letter-spacing: 1px;
		transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
		clip-path: polygon(
			0 0, 
			calc(100% - 10px) 0, 
			100% 10px, 
			100% 100%, 
			0 100%
		);
	}

	.version-tab:hover {
		color: #00f0ff;
		border-color: #00f0ff;
		background: rgba(0, 240, 255, 0.15);
	}

	.version-tab.active {
		color: #fff;
		border-color: #00f0ff;
		background: rgba(0, 240, 255, 0.25);
		box-shadow: 0 0 15px rgba(0, 240, 255, 0.1);
		text-shadow: 0 0 8px rgba(0, 240, 255, 0.5);
	}

	.version-content {
		display: none;
	}

	.version-content.active {
		display: block;
		animation: versionFadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);
	}

	@keyframes versionFadeIn {
		from { 
			opacity: 0; 
			transform: translateY(10px);
			filter: blur(5px);
		}
		to { 
			opacity: 1; 
			transform: translateY(0);
			filter: blur(0);
		}
	}

	.notification-item {
		margin-bottom: 25px;
	}

	.notification-item:last-child {
		margin-bottom: 0;
	}

	.cyan-text {
		color: #00f0ff;
		margin-top: 0;
		margin-bottom: 10px;
		font-size: 1.1rem;
		font-weight: normal;
	}

	ul {
		list-style-type: none;
		padding-left: 25px;
		margin: 0;
	}

	ul li {
		margin-bottom: 5px;
		color: #e0ffff;
		position: relative;
	}

	ul li::before {
		content: "▶";
		position: absolute;
		left: -15px;
		color: #00f0ff;
		font-size: 0.8rem;
		top: 2px;
	}

	.download-btn-wrap {
		margin-top: 20px;
		margin-bottom: 15px;
		max-width: 240px;
	}

	.site-footer {
		text-align: center;
		margin-top: 50px;
		font-size: 0.8rem;
		color: rgba(224, 255, 255, 0.5);
	}

	.retro-btn {
		display: block;
		width: 100%;
		text-decoration: none;
		background-size: 100% 100%;
		background-repeat: no-repeat;
		background-position: center;
		background-color: transparent;
		border: none;
		cursor: pointer;
		transition: filter 0.2s;
	}

	.btn-inner {
		display: block;
		text-align: center;
		padding: 12px 20px;
		color: #30da96;
		font-family: inherit;
		font-size: 0.9rem;
		font-weight: normal;
		letter-spacing: 2px;
		text-transform: capitalize;
		transition: color 0.2s;
	}

	.retro-btn:hover {
		filter: drop-shadow(0 0 5px rgba(0, 240, 255, 0.4));
	}

	.retro-btn:hover .btn-inner {
		color: #ffffff;
		text-shadow: 0 0 8px #00f0ff;
	}

	.modal-overlay {
		position: fixed;
		inset: 0;
		z-index: 2000;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(0, 0, 0, 0);
		pointer-events: none;
		transition: background 0.3s ease;
	}

	.modal-overlay.active {
		background: rgba(0, 0, 0, 0.7);
		pointer-events: auto;
	}

	.modal-box {
		position: relative;
		width: 90%;
		max-width: 400px;
		padding: 20px;
		background: rgba(8, 28, 29, 0.95);
		transform: translateX(100vw);
		opacity: 0;
		transition:
			transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
			opacity 0.3s ease;
		clip-path: polygon(
			0 0,
			calc(100% - 20px) 0,
			100% 20px,
			100% 100%,
			20px 100%,
			0 calc(100% - 20px)
		);
	}

	.modal-box::before {
		content: "";
		position: absolute;
		inset: -2px;
		border: 45px solid transparent;
		border-image-source: var(--border-img);
		border-image-slice: 100 120 100 120;
		border-image-repeat: stretch;
		pointer-events: none;
	}

	.modal-overlay.active .modal-box {
		transform: translateX(0);
		opacity: 1;
	}

	.modal-overlay.closing .modal-box {
		transform: translateX(100vw);
		opacity: 0;
		transition:
			transform 0.35s cubic-bezier(0.64, 0, 0.78, 0),
			opacity 0.3s ease;
	}

	.modal-title {
		position: relative;
		text-align: center;
		color: #e0ffff;
		font-weight: normal;
		font-size: 1.2rem;
		margin: 0 0 20px 0;
		letter-spacing: 2px;
	}

	.modal-content {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 12px;
		padding: 0 15px 10px;
	}

	.close-btn {
		position: absolute;
		top: 10px;
		right: 15px;
		background: none;
		border: none;
		color: #e0ffff;
		font-size: 1.5rem;
		cursor: pointer;
		z-index: 1;
		line-height: 1;
		transition: color 0.2s;
	}

	.close-btn:hover {
		color: #00f0ff;
	}
</style>
