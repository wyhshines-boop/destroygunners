---
import borderImg from '../img/border.webp';

interface Props {
	title?: string;
}

const { title } = Astro.props;
---

<div class="sf-box" style={`--border-img: url('${borderImg.src}');`}>
	{title && <h2 class="box-title">{title}</h2>}
	<div class="box-content">
		<slot />
	</div>
</div>

<style>
	.sf-box {
		position: relative;
		display: block;
		margin: 25px 0;
		padding: 15px;
		background: rgba(8, 28, 29, 0.85);
		clip-path: polygon(
			0 0,
			calc(100% - 20px) 0,
			100% 20px,
			100% 100%,
			20px 100%,
			0 calc(100% - 20px)
		);
	}

	.sf-box::before {
		content: '';
		position: absolute;
		inset: -2px; /* 稍微向外扩展一点以确保覆盖 */
		border: 45px solid transparent; /* 边框厚度 */
		border-image-source: var(--border-img);
		border-image-slice: 100 120 100 120; /* 关键：根据 border.webp (1024x582) 的比例切片 */
		border-image-repeat: stretch;
		pointer-events: none;
		filter: drop-shadow(0 0 10px rgba(0, 240, 255, 0.1));
	}

	.box-title {
		position: relative;
		text-align: center;
		color: #e0ffff;
		font-weight: normal;
		font-size: 1.2rem;
		margin: 0;
		padding: 15px 0 0 0;
		letter-spacing: 2px;
	}

	.box-content {
		position: relative;
		padding: 15px 25px;
	}
</style>
