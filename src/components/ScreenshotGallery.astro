---
import img1 from "../img/dgzz/dgzz1.webp";
import img2 from "../img/dgzz/dgzz2.webp";
import img3 from "../img/dgzz/dgzz3.webp";
import img4 from "../img/dgzz/dgzz4.webp";

const screenshots = [img1, img2, img3, img4];
---

<div class="gallery-wrapper">
    <div class="gallery-scroll">
        {
            screenshots.map((img, index) => (
                <div class="gallery-item" data-index={index}>
                    <div class="img-frame">
                        <img
                            src={img.src}
                            alt={`Screenshot ${index + 1}`}
                            class="gallery-thumb"
                            loading="lazy"
                        />
                    </div>
                </div>
            ))
        }
    </div>
    <div class="fake-scrollbar" aria-hidden="true">
        <div class="fake-thumb"></div>
    </div>
</div>

<!-- Lightbox lives here but gets teleported to body via JS -->
<div id="gallery-lightbox" class="lightbox-overlay" style="display:none;">
    <div class="lightbox-backdrop"></div>
    <div class="lightbox-content">
        <button
            id="gallery-close-btn"
            class="lightbox-close"
            aria-label="Close"
        >
            <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
        </button>
        <img id="gallery-lightbox-img" src="" alt="Enlarged screenshot" />
    </div>
</div>

<script>
    function initGallery() {
        // Teleport lightbox to body to escape any parent clip-path
        const lightbox = document.getElementById("gallery-lightbox");
        if (lightbox && lightbox.parentElement !== document.body) {
            document.body.appendChild(lightbox);
            lightbox.style.display = "";
        }

        const thumbs = document.querySelectorAll(".gallery-thumb");
        const lightboxImg = document.getElementById(
            "gallery-lightbox-img",
        ) as HTMLImageElement;
        const closeBtn = document.getElementById("gallery-close-btn");
        const backdrop = lightbox?.querySelector(".lightbox-backdrop");

        if (!lightbox || !lightboxImg) return;

        const openLightbox = (src: string) => {
            lightboxImg.src = src;
            lightbox.classList.add("active");
            document.body.style.overflow = "hidden";
        };

        const closeLightbox = () => {
            lightbox.classList.remove("active");
            document.body.style.overflow = "";
        };

        // Attach click only once per thumb
        thumbs.forEach((thumb) => {
            if ((thumb as HTMLElement).dataset.lightboxInit) return;
            (thumb as HTMLElement).dataset.lightboxInit = "true";
            thumb.addEventListener("click", () => {
                openLightbox((thumb as HTMLImageElement).src);
            });
        });

        if (closeBtn && !(closeBtn as HTMLElement).dataset.lightboxInit) {
            (closeBtn as HTMLElement).dataset.lightboxInit = "true";
            closeBtn.addEventListener("click", closeLightbox);
        }

        if (backdrop && !(backdrop as HTMLElement).dataset.lightboxInit) {
            (backdrop as HTMLElement).dataset.lightboxInit = "true";
            backdrop.addEventListener("click", closeLightbox);
        }

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && lightbox.classList.contains("active")) {
                closeLightbox();
            }
        });
    }

    function initFakeScrollbar() {
        const scrolls = document.querySelectorAll<HTMLElement>(".gallery-scroll");
        scrolls.forEach((scroll) => {
            if (scroll.dataset.fakeSbInit) return;
            scroll.dataset.fakeSbInit = "true";

            const wrapper = scroll.parentElement;
            if (!wrapper) return;
            const bar = wrapper.querySelector<HTMLElement>(".fake-scrollbar");
            const thumb = wrapper.querySelector<HTMLElement>(".fake-thumb");
            if (!bar || !thumb) return;

            const update = () => {
                const { scrollLeft, scrollWidth, clientWidth } = scroll;
                const max = scrollWidth - clientWidth;
                if (max <= 0) {
                    bar.style.display = "none";
                    return;
                }
                bar.style.display = "";
                const barWidth = bar.clientWidth;
                const ratio = clientWidth / scrollWidth;
                const thumbWidth = Math.max(24, barWidth * ratio);
                const offset = (scrollLeft / max) * (barWidth - thumbWidth);
                thumb.style.width = thumbWidth + "px";
                thumb.style.transform = `translateX(${offset}px)`;
            };

            scroll.addEventListener("scroll", update, { passive: true });
            window.addEventListener("resize", update);
            // Run after layout/images settle
            requestAnimationFrame(update);
            setTimeout(update, 300);
        });
    }

    initGallery();
    initFakeScrollbar();
    document.addEventListener("astro:page-load", () => {
        initGallery();
        initFakeScrollbar();
    });
</script>

<style is:global>
    .lightbox-overlay {
        position: fixed;
        inset: 0;
        z-index: 9000;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }

    .lightbox-overlay.active {
        opacity: 1;
        pointer-events: auto;
    }

    .lightbox-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.88);
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
    }

    .lightbox-close {
        position: absolute;
        top: -42px; /* Above image on mobile */
        right: 0;
        z-index: 9002;
        background: rgba(0, 0, 0, 0.7);
        border: 1px solid rgba(0, 240, 255, 0.6);
        width: 34px;
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #00f0ff; /* Border color */
        cursor: pointer;
        transition: all 0.2s;
    }

    @media (min-width: 768px) {
        .lightbox-close {
            top: 0;
            right: -42px; /* Outside right of image on desktop */
        }
    }

    .lightbox-close svg {
        width: 20px;
        height: 20px;
    }

    .lightbox-close:hover {
        background: #00f0ff;
        color: #000;
        box-shadow: 0 0 10px rgba(0, 240, 255, 0.5);
    }

    .lightbox-content {
        position: relative;
        z-index: 9001;
        max-width: calc(
            100vw - 100px
        ); /* Leave room for close button on sides */
        max-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .lightbox-content img {
        max-width: 100%;
        max-height: 90vh;
        object-fit: contain;
        border: 2px solid #00f0ff;
        box-shadow:
            0 0 60px rgba(0, 0, 0, 0.9),
            0 0 30px rgba(0, 240, 255, 0.3);
        animation: lightboxIn 0.25s ease;
    }

    @keyframes lightboxIn {
        from {
            transform: scale(0.92);
            opacity: 0;
        }
        to {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>

<style>
    .gallery-wrapper {
        margin-top: 30px;
    }

    .gallery-scroll {
        display: flex;
        gap: 12px;
        overflow-x: auto;
        padding-bottom: 0;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none; /* Firefox */
    }
    .gallery-scroll::-webkit-scrollbar {
        display: none; /* Safari / Chrome */
    }

    /* Fake scrollbar (mobile only) */
    .fake-scrollbar {
        position: relative;
        height: 12px;
        margin-top: 10px;
        display: flex;
        align-items: center;
    }
    .fake-scrollbar::before {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        top: 50%;
        height: 1px;
        background: rgba(0, 240, 255, 0.35);
        transform: translateY(-0.5px);
    }
    .fake-thumb {
        position: relative;
        height: 3px;
        background: #00f0ff;
        box-shadow: 0 0 4px rgba(0, 240, 255, 0.6);
        will-change: transform, width;
        transition: width 0.15s ease;
    }

    @media (min-width: 768px) {
        .gallery-scroll {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            overflow-x: visible;
            scroll-snap-type: none;
        }
        .fake-scrollbar {
            display: none;
        }
    }

    .gallery-item {
        flex: 0 0 80%;
        scroll-snap-align: center;
        cursor: zoom-in;
        transition: transform 0.25s ease;
    }

    @media (min-width: 768px) {
        .gallery-item {
            flex: none;
        }
        .gallery-item:hover {
            transform: scale(1.05);
            z-index: 10;
        }
    }

    .img-frame {
        border: 2px solid rgba(0, 240, 255, 0.3);
        background: rgba(8, 28, 29, 0.9);
        padding: 4px;
        clip-path: polygon(
            0 0,
            calc(100% - 14px) 0,
            100% 14px,
            100% 100%,
            14px 100%,
            0 calc(100% - 14px)
        );
        box-shadow: 0 0 12px rgba(0, 0, 0, 0.5);
        transition: border-color 0.2s;
    }

    .gallery-item:hover .img-frame {
        border-color: rgba(0, 240, 255, 0.7);
    }

    .gallery-thumb {
        width: 100%;
        height: auto;
        display: block;
        transition: filter 0.25s;
    }

    .gallery-item:hover .gallery-thumb {
        filter: brightness(1.15);
    }

</style>
